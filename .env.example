# apps/web — Vite env (VITE_ prefix is exposed to the browser)

# Supabase auth (production path)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend service base URLs
VITE_API_BASE_URL=http://localhost:8030
VITE_SKILL_GAP_URL=http://localhost:8031
VITE_RECOMMENDATION_URL=http://localhost:8032

# Dev/demo only: a JWT minted with the backend JWT_SECRET (HS256, claims: sub,
# role). When set, Supabase auth is bypassed and this token is sent as the
# bearer to all services. NEVER set in production.
# VITE_DEV_JWT=
